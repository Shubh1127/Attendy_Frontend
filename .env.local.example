# ─────────────────────────────────────────────────────────────────
# Snap Class — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────

# ── Python ML Backend ────────────────────────────────────────────
# Base URL of your FastAPI/Flask attendance backend.
# Leave unset (or set NEXT_PUBLIC_USE_MOCKS=true) to use built-in
# mock data — useful for local frontend development without the backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Mock mode override ────────────────────────────────────────────
# Force mocks ON even when NEXT_PUBLIC_API_BASE_URL is set.
# Set to "false" in staging/production to hit the real backend.
NEXT_PUBLIC_USE_MOCKS=true

# ── Supabase ──────────────────────────────────────────────────────
# These two are safe to expose in the browser (anon key only).
# The service-role key must NEVER appear in any NEXT_PUBLIC_ variable.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
